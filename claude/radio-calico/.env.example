# RadioCalico local prototyping environment
# Copy this file to `.env` and adjust as needed.
# These are LOCAL DEV credentials only — do not reuse in production.

# --- PostgreSQL ---
POSTGRES_USER=radiocalico
POSTGRES_PASSWORD=radiocalico_dev
POSTGRES_DB=radiocalico
# Host port the DB is published on (connect from your machine at localhost:5432)
DB_HOST_PORT=5432

# --- Nginx web server ---
# Browse the site at http://localhost:8080
WEB_HOST_PORT=8080
